{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "articleTitle": {
      "type": "uid",
      "targetField": "Title"
    },
    "Title": {
      "type": "text"
    },
    "Content": {
      "type": "blocks"
    },
    "Thumbnail": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Published_Date": {
      "type": "date"
    },
    "Category": {
      "type": "text"
    },
    "metaTitle": {
      "type": "text"
    },
    "metaDescription": {
      "type": "text"
    },
    "ShownInHome": {
      "type": "boolean"
    },
    "ShownInHeaderArticle": {
      "type": "boolean"
    }
  }
}
